# ============================================================
# QuantVista 环境变量示例
# 用法：复制本文件为 deploy/.env 并填入真实值（deploy/.env 已在 .gitignore，不会提交）
# ============================================================

# ---- 镜像与容器 ----
# 构建时使用的镜像 tag，与「编译推送步骤.md」里保持一致
IMAGE=raoczh/quantvista:custom-YYYYMMDD-01
CONTAINER_NAME=quantvista
# 宿主机数据/日志目录（宝塔下通常在 /www/wwwroot/quantvista）
APP_PATH=/www/wwwroot/quantvista

# ---- 端口 ----
# 容器内监听端口
PORT=3000
# 宿主机映射端口（避开 new-api 的 3001）
WEB_HTTP_PORT=3002

# ---- 数据库（MySQL）----
# 宝塔容器编排里，宿主机 MySQL 通过 host-gateway 网段访问，DB_HOST 一般是 172.18.0.1
DB_HOST=172.18.0.1
DB_PORT=3306
DB_NAME=quantvista
DB_USER=quantvista
DB_PASSWORD=please-change-me
# GORM DSN（程序启动时用它连库并自动建表/迁移）
SQL_DSN=${DB_USER}:${DB_PASSWORD}@tcp(${DB_HOST}:${DB_PORT})/${DB_NAME}?charset=utf8mb4&parseTime=true&loc=Local

# ---- Redis ----
# 使用 compose 内置的 quantvista-redis 服务
REDIS_CONN_STRING=redis://quantvista-redis:6379/0

# ---- 安全 ----
# 用 `openssl rand -base64 36` 生成一个随机串
SESSION_SECRET=please-generate-a-random-secret
# API Key / 数据源密钥的加密主密钥（务必与 SESSION_SECRET 不同，32 字节以上）
ENCRYPTION_KEY=please-generate-another-random-secret
# 生产环境 CORS 白名单（逗号分隔）。前后端同源部署可留空；仅当从别的域名跨域调 API 时才需填。
# 例：ALLOWED_ORIGINS=https://quant.example.com
ALLOWED_ORIGINS=
# 反向代理（宝塔/nginx）场景的可信代理地址（逗号分隔，可为 IP 或 CIDR）。
# 只有来自可信代理的 X-Forwarded-For 才会被采信为客户端真实 IP（登录限流、日志按 IP 统计）。
# 留空 = 不信任任何代理头（直连部署用）；nginx 反代在同宿主机时通常填 172.18.0.1 或宿主网段。
# 例：TRUSTED_PROXIES=172.18.0.1
TRUSTED_PROXIES=

# ---- 第三方登录：GitHub OAuth（可选，凭证以后台配置为准）----
# 凭证落库（系统设置表，secret 加密存储），登录后在「管理后台 → GitHub 登录」配置。
# 下面两个 env 仅作首启「种子」：若 DB 尚无值且 env 提供了，启动时回填到 DB；之后以后台为准。
# GitHub OAuth App 的 Authorization callback URL 需设为：<站点地址>/login/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ---- 行情数据源（阶段 0 先打通一个）----
# Tushare Pro token（A 股财务/日线，可选）
TUSHARE_TOKEN=
# 数据源默认市场：cn / us / hk
DEFAULT_MARKET=cn

# ---- 自建 ntfy 推送服务（可选，Android App 系统级推送）----
# ntfy 对外访问地址（CF 子域 + 宝塔反代到容器 3003，部署见 docs/DEPLOYMENT.md §8）。
# 仅供 ntfy 容器自身生成正确链接用；后端推送地址由用户在「条件提醒 → 推送通道」里逐通道配置。
NTFY_BASE_URL=https://ntfy.example.com

# ---- 其他 ----
TZ=Asia/Shanghai
# DEBUG=false
