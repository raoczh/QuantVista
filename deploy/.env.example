# ============================================================
# QuantVista 环境变量示例
# 用法：复制本文件为 deploy/.env 并填入真实值（deploy/.env 已在 .gitignore，不会提交）
# ============================================================

# ---- 镜像与容器 ----
# 构建时使用的镜像 tag，与「编译推送步骤.md」里保持一致
IMAGE=raoczh/quantvista:custom-YYYYMMDD-01
CONTAINER_NAME=quantvista
# 宿主机数据/日志目录（宝塔下通常在 /www/wwwroot/quantvista）
APP_PATH=/www/wwwroot/quantvista

# ---- 端口 ----
# 容器内监听端口
PORT=3000
# 宿主机映射端口（避开 new-api 的 3001）
WEB_HTTP_PORT=3002

# ---- 数据库（MySQL）----
# 宝塔容器编排里，宿主机 MySQL 通过 host-gateway 网段访问，DB_HOST 一般是 172.18.0.1
DB_HOST=172.18.0.1
DB_PORT=3306
DB_NAME=quantvista
DB_USER=quantvista
DB_PASSWORD=please-change-me
# GORM DSN（程序启动时用它连库并自动建表/迁移）
SQL_DSN=${DB_USER}:${DB_PASSWORD}@tcp(${DB_HOST}:${DB_PORT})/${DB_NAME}?charset=utf8mb4&parseTime=true&loc=Local

# ---- Redis ----
# 使用 compose 内置的 quantvista-redis 服务
REDIS_CONN_STRING=redis://quantvista-redis:6379/0

# ---- 安全 ----
# 用 `openssl rand -base64 36` 生成一个随机串
SESSION_SECRET=please-generate-a-random-secret
# API Key / 数据源密钥的加密主密钥（务必与 SESSION_SECRET 不同，32 字节以上）
ENCRYPTION_KEY=please-generate-another-random-secret

# ---- 第三方登录：GitHub OAuth ----
GITHUB_CLIENT_ID=your-github-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-github-oauth-app-client-secret

# ---- 行情数据源（阶段 0 先打通一个）----
# Tushare Pro token（A 股财务/日线，可选）
TUSHARE_TOKEN=
# 数据源默认市场：cn / us / hk
DEFAULT_MARKET=cn

# ---- 其他 ----
TZ=Asia/Shanghai
ERROR_LOG_ENABLED=true
# DEBUG=false
